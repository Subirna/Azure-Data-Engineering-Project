{
    "name": "UK Traffic Intelligence Dark",
    "dataColors": [
        "#3B82F6",
        "#EF4444",
        "#10B981",
        "#F59E0B",
        "#8B5CF6",
        "#EC4899",
        "#14B8A6",
        "#F97316",
        "#06B6D4",
        "#84CC16",
        "#E11D48"
    ],
    "background": "#111827",
    "foreground": "#F3F4F6",
    "tableAccent": "#3B82F6",
    "visualStyles": {
        "*": {
            "*": {
                "background": [{"color": {"solid": {"color": "#1F2937"}}}],
                "border": [{"color": {"solid": {"color": "#374151"}}, "show": true}],
                "title": [{
                    "show": true,
                    "fontColor": {"solid": {"color": "#F3F4F6"}},
                    "fontSize": 12,
                    "bold": true
                }],
                "labels": [{"color": {"solid": {"color": "#9CA3AF"}}}]
            }
        },
        "page": {
            "*": {
                "background": [{"color": {"solid": {"color": "#111827"}}, "transparency": 0}]
            }
        },
        "card": {
            "*": {
                "background": [{"color": {"solid": {"color": "#1F2937"}}}],
                "categoryLabel": [{"color": {"solid": {"color": "#9CA3AF"}}, "fontSize": 10}],
                "wordWrap": [{"show": true}]
            }
        },
        "slicer": {
            "*": {
                "background": [{"color": {"solid": {"color": "#1F2937"}}}]
            }
        },
        "textbox": {
            "*": {
                "background": [{"color": {"solid": {"color": "#111827"}}, "transparency": 100}]
            }
        }
    }
}
